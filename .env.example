# Anthropic (필수)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangSmith (선택 - 다음 주 관측성)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=mac-idea-agent

# Reddit API (선택 - 없으면 Mock으로 대체)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# YouTube Data API v3 (선택 - 없으면 Mock으로 대체)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Gemini 임베딩 (선택 - 유사 앱 의미 유사도 판정용)
# 없으면 글자 매칭 fallback으로 강등(similarity_score=None, interrupt 미발생)
# 발급: https://aistudio.google.com/apikey  (무료 티어로 충분)
GOOGLE_API_KEY=your_google_api_key_here
